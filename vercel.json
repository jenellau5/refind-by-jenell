{
  "version": 2,
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "framework": null,
  "functions": {
    "api/server.js": {
      "runtime": "nodejs20.x",
      "memory": 1024,
      "maxDuration": 30,
      "includeFiles": "dist/**,node_modules/better-sqlite3/**,node_modules/bindings/**,node_modules/file-uri-to-path/**"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/server" },
    { "source": "/uploads/:path*", "destination": "/api/server" },
    { "source": "/((?!_next|assets|favicon).*)", "destination": "/index.html" }
  ],
  "outputDirectory": "dist/public"
}
